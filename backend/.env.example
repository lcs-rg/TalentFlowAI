# Backend — Supabase PostgreSQL
DATABASE_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_USERNAME=postgres.<SEU_PROJECT_REF>
DATABASE_PASSWORD=<SUA_SENHA_DB>

# JWT (gere um segredo de 64+ caracteres)
JWT_SECRET=seu-segredo-super-longo-com-pelo-menos-64-caracteres-aqui-1234567890

# OpenAI
OPENAI_API_KEY=sk-...

# Supabase Storage
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_KEY=eyJh...
SUPABASE_PROJECT_REF=<PROJECT_REF>

# Redis (opcional na V1 — usa Docker local)
REDIS_HOST=localhost
REDIS_PORT=6379
